---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
import NewsCard from '../components/NewsCard.astro';
import { assetUrl } from '../lib/asset-url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const researchNews = (await getCollection('news'))
  .filter(p => !p.data.draft && p.data.tags.includes('research'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const focusAreas = [
  {
    title: 'Automotive powertrains',
    body: 'Conventional, hybrid, and electric propulsion systems. Engine and motor integration, transmission analysis, and powertrain-level control.'
  },
  {
    title: 'Battery systems',
    body: 'Cell characterization, module and pack design, thermal management, and battery management systems built around the Battery Workforce Challenge platform.'
  },
  {
    title: 'Electric and hybrid vehicles',
    body: 'Full-vehicle integration of electrified powertrains. Energy storage, power electronics, and drivetrain architecture trade studies.'
  },
  {
    title: 'Autonomy and ADAS',
    body: 'Perception, planning, and control for advanced driver assistance and automated driving systems. Sensor integration, validation, and safety case development.'
  },
  {
    title: 'Vehicle-level energy modeling',
    body: 'Simulation and analysis of real-world vehicle energy use. Drive cycle analysis, fleet telematics, and connected and automated vehicle impact studies.'
  }
];

const capstoneHighlights = [
  {
    title: 'Hot-swappable battery pack',
    image: '/images/capstone-hot-swap.jpg',
    alt: 'Mines capstone students working on a hot-swappable battery pack prototype',
    summary: 'Senior design team delivered a hot-swap battery prototype for a sponsor vehicle, targeting rapid field replacement for fleet applications.'
  },
  {
    title: '24 Hours of Lemons',
    image: '/images/capstone-lemons.jpg',
    alt: 'Mines 24 Hours of Lemons endurance race car built by capstone students',
    summary: 'Endurance race build: capstone students designed, prepped, and raced an economy-class car through the 24 Hours of Lemons endurance series.'
  },
  {
    title: 'National lab collaboration',
    image: null,
    alt: '',
    summary: 'Coming soon. Ongoing national lab collaboration capstone highlights will be featured in this slot.'
  }
];
---

<BaseLayout
  title="Research"
  description="Research in the Mines Automotive Engineering Program spans powertrains, battery systems, electric and hybrid vehicles, autonomy and ADAS, and vehicle-level energy modeling."
  canonicalPath="/research/"
>
  <Nav slot="nav" currentPath={Astro.url.pathname} />

  <PageHeader
    title="Research"
    lead="Automotive research at Mines bridges fundamental engineering, national lab collaboration, and live industry problems."
    breadcrumb={[{ label: 'Home', href: `${base}/` }, { label: 'Research' }]}
  />

  <section class="bg-white">
    <div class="mx-auto max-w-(--container-content) px-6 py-12 md:py-16">
      <div class="max-w-3xl text-lg text-(--color-body)">
        <p>
          Program research sits at the intersection of mechanical engineering, electrical systems, and vehicle-level integration. Faculty draw on years of national lab experience and industry work to shape projects that matter to the transportation sector, while giving undergraduate and graduate students access to real engineering problems.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-(--color-mines-pale-blue)/40">
    <div class="mx-auto max-w-(--container-content) px-6 py-16 md:py-20">
      <div class="max-w-2xl">
        <span class="block h-1 w-16 bg-(--color-mines-red) mb-4" aria-hidden="true"></span>
        <h2 class="text-3xl md:text-4xl font-bold text-(--color-mines-blue)">Focus areas</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {focusAreas.map(area => (
          <article class="rounded border border-(--color-mines-pale-blue) bg-white p-6">
            <h3 class="text-lg font-bold text-(--color-mines-blue)">{area.title}</h3>
            <p class="mt-3 text-sm text-(--color-body)">{area.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {researchNews.length > 0 && (
    <section class="bg-white">
      <div class="mx-auto max-w-(--container-content) px-6 py-16 md:py-20">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
          <div class="max-w-2xl">
            <span class="block h-1 w-16 bg-(--color-mines-red) mb-4" aria-hidden="true"></span>
            <h2 class="text-3xl md:text-4xl font-bold text-(--color-mines-blue)">Research news</h2>
          </div>
          <a href={`${base}/news/`} class="text-sm font-bold text-(--color-mines-red) hover:underline">All news →</a>
        </div>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {researchNews.map(post => <NewsCard post={post} />)}
        </div>
      </div>
    </section>
  )}

  <section class="bg-(--color-mines-pale-blue)/40">
    <div class="mx-auto max-w-(--container-content) px-6 py-16 md:py-20">
      <div class="max-w-2xl">
        <span class="block h-1 w-16 bg-(--color-mines-red) mb-4" aria-hidden="true"></span>
        <h2 class="text-3xl md:text-4xl font-bold text-(--color-mines-blue)">Capstone highlights</h2>
        <p class="mt-3 text-(--color-body)">Senior design teams deliver industry-sponsored vehicle engineering projects each spring. Recent highlights will be posted here as teams complete their work.</p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {capstoneHighlights.map(item => (
          <article class="rounded border border-(--color-mines-pale-blue) bg-white overflow-hidden">
            {item.image ? (
              <img src={assetUrl(item.image)} alt={item.alt} class="aspect-[16/9] w-full object-cover" loading="lazy" />
            ) : (
              <div class="aspect-[16/9] w-full bg-(--color-mines-pale-blue)" aria-hidden="true"></div>
            )}
            <div class="p-6">
              <h3 class="text-lg font-bold text-(--color-mines-blue)">{item.title}</h3>
              <p class="mt-2 text-sm text-(--color-body)">{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    headline="Collaborate with the program"
    body="Industry partners, national labs, and prospective graduate students: reach out to discuss sponsored projects, joint research, or student involvement."
    primary={{ href: `${base}/contact/`, label: 'Start a conversation' }}
    secondary={{ href: `${base}/partners/`, label: 'See current partners' }}
  />

  <Footer slot="footer" />
</BaseLayout>
