---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
import { assetUrl } from '../lib/asset-url';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const teams = (await getCollection('teams')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<BaseLayout
  title="Competition teams"
  description="Four flagship competition teams anchor the Mines automotive program: Formula SAE, Shell Eco-marathon, Battery Workforce Challenge, and EcoCAR."
  canonicalPath="/teams/"
>
  <Nav slot="nav" currentPath={Astro.url.pathname} />

  <PageHeader
    title="Competition teams"
    lead="Four flagship teams take coursework from theory to track."
    breadcrumb={[{ label: 'Home', href: `${base}/` }, { label: 'Teams' }]}
  />

  <section class="bg-white">
    <div class="mx-auto max-w-(--container-content) px-6 py-12 md:py-16">
      <div class="max-w-3xl text-lg text-(--color-body)">
        <p>
          The competition teams are the program's front door. A first-year student who joins in the fall has met every track instructor and seen real automotive engineering work before the spring semester starts. Teams are advised by program faculty and supported by industry and national lab partners.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-(--color-mines-pale-blue)/40">
    <div class="mx-auto max-w-(--container-content) px-6 py-16 md:py-20">
      <div class="grid gap-6 md:grid-cols-2">
        {teams.map(team => (
          <a
            href={`${base}/teams/${team.id.replace(/\.md$/, '')}/`}
            class="group block rounded border border-(--color-mines-pale-blue) bg-white overflow-hidden transition-colors hover:border-(--color-mines-red)"
          >
            {team.data.thumbnail && (
              <div class="aspect-[16/9] w-full overflow-hidden">
                <img src={assetUrl(team.data.thumbnail)} alt="" class="h-full w-full object-cover" loading="lazy" />
              </div>
            )}
            <div class="p-6">
              <h2 class="text-xl font-bold text-(--color-mines-blue) group-hover:text-(--color-mines-red)">{team.data.title}</h2>
              <p class="mt-3 text-(--color-body)">{team.data.description}</p>
              {team.data.role && (
                <p class="mt-4 text-sm text-(--color-caption)"><span class="font-semibold">Student role:</span> {team.data.role}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    headline="Ready to join a team?"
    body="Teams recruit every fall and spring. Reach out to learn about tryouts, roles, and current projects."
    primary={{ href: `${base}/contact/`, label: 'Get in touch' }}
    secondary={{ href: `${base}/curriculum/`, label: 'See related courses' }}
  />

  <Footer slot="footer" />
</BaseLayout>
