---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';
import FacultyCard from '../components/FacultyCard.astro';
import { faculty } from '../data/faculty';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Faculty"
  description="Meet the faculty leading the Mines Automotive Engineering Program: Adam Duran and Polina Brodsky."
  canonicalPath="/faculty/"
>
  <Nav slot="nav" currentPath={Astro.url.pathname} />

  <PageHeader
    title="Faculty"
    lead="The program is co-led by two Assistant Teaching Professors with deep industry, national lab, and student team experience."
    breadcrumb={[{ label: 'Home', href: `${base}/` }, { label: 'Faculty' }]}
  />

  <section class="bg-white">
    <div class="mx-auto max-w-(--container-content) px-6 py-12 md:py-16">
      <div class="max-w-3xl text-lg text-(--color-body)">
        <p>
          Program faculty teach the automotive track core courses, advise the four flagship competition teams, and mentor independent study and graduate research students. Reach out directly for course questions, research collaborations, or advising.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-(--color-mines-pale-blue)/40">
    <div class="mx-auto max-w-(--container-content) px-6 py-16 md:py-20">
      <div class="flex flex-col gap-6">
        {faculty.map(person => <FacultyCard person={person} />)}
      </div>
    </div>
  </section>

  <CTASection
    headline="Interested in working with us?"
    body="Prospective students, collaborators, and industry partners: get in touch to discuss courses, research, or program involvement."
    primary={{ href: `${base}/contact/`, label: 'Contact the program' }}
    secondary={{ href: `${base}/research/`, label: 'See research areas' }}
  />

  <Footer slot="footer" />
</BaseLayout>
