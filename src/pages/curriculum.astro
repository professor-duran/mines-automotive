---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import PhotoTextRow from '../components/PhotoTextRow.astro';
import CTASection from '../components/CTASection.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allCourses = (await getCollection('courses')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
const previewCourses = allCourses.slice(0, 6);
---

<BaseLayout
  title="Curriculum"
  description="Required track courses, curated electives for focus areas, and a hands-on competition-team ecosystem, organized around three pillars: technical depth, hands-on experience, and industry connection."
  canonicalPath="/curriculum/"
>
  <Nav slot="nav" currentPath={Astro.url.pathname} />

  <PageHeader
    title="Curriculum"
    lead="Two required track courses, curated focus-area electives, and experiential coursework, organized around three pillars."
    breadcrumb={[{ label: 'Home', href: `${base}/` }, { label: 'Curriculum' }]}
  />

  <PhotoTextRow
    image={`${base}/images/capstone-simulator.jpg`}
    alt="Students operating the multiaxis driving simulator built for MEGN 417/527 Vehicle Dynamics"
    heading="Technical depth"
  >
    <p>
      The track is anchored by two required courses. <strong>MEGN 391 Introduction to Automotive Design</strong> rebuilds design-build-test fundamentals around student-built RC cars. <strong>MEGN 417/527 Vehicle Dynamics</strong> covers suspension, tire, and powertrain dynamics through calculation, simulation, and experimentation, with an integrated electric go-kart platform and a multiaxis driving simulator as the verification bench.
    </p>
    <p>
      Students then select from a curated elective slate to specialize toward a focus area: vibrations, controls, electric vehicle powertrains, fuel cells, combustion, aerodynamics, or CFD. Track faculty also teach core ME courses (MEGN 200 Intro to ME, MEGN 300 Instrumentation, MEGN 301 Mechanical Integration) whose open materials are released under CC BY 4.0 on GitHub.
    </p>
  </PhotoTextRow>

  <PhotoTextRow
    image={`${base}/images/bwc-workshop.jpg`}
    alt="Mines and ACC Battery Workforce Challenge team at work in the shop"
    reverse={true}
    heading="Hands-on experience"
  >
    <p>
      Coursework is paired with lab-heavy project work from the first year forward. MEGN 200 students learn embedded C and hardware debugging. MEGN 301 teams translate thermodynamics and mechanics of materials into working prototypes. Capstone teams deliver instrumented hardware to industry sponsors.
    </p>
    <p>
      Four flagship competition teams anchor the experiential side: FSAE, Shell Eco-marathon, the Battery Workforce Challenge, and EcoCAR. Students build, test, and race the vehicles they analyze in class.
    </p>
  </PhotoTextRow>

  <PhotoTextRow
    image={`${base}/images/capstone-automotive-projects.jpg`}
    alt="Capstone automotive projects on display"
    heading="Industry connection"
  >
    <p>
      Industry partnerships with Stellantis, NREL, and other OEMs, Tier 1 suppliers, and national lab collaborators keep course content current and feed directly into capstone projects, internships, and graduate placement. Competition programs like EcoCAR and the Battery Workforce Challenge connect students to real OEM engineering teams.
    </p>
    <p>
      Federal-facing courses taught by program faculty (MEGN 455 Aerospace Systems Engineering, MEGN 456 Space Operations and Mission Design) sharpen requirements-writing, trade-study, and proposal skills that transfer directly to vehicle programs.
    </p>
  </PhotoTextRow>

  <section class="bg-(--color-mines-pale-blue)/40">
    <div class="mx-auto max-w-(--container-content) px-6 py-16 md:py-20">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div class="max-w-2xl">
          <span class="block h-1 w-16 bg-(--color-mines-red) mb-4" aria-hidden="true"></span>
          <h2 class="text-3xl md:text-4xl font-bold text-(--color-mines-blue)">Course preview</h2>
          <p class="mt-3 text-(--color-body)">A sample of the automotive track courses. See the full catalog for prerequisites, semesters, and open materials.</p>
        </div>
        <a href={`${base}/courses/`} class="text-sm font-bold text-(--color-mines-red) hover:underline">See all courses →</a>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {previewCourses.map(course => (
          <article class="rounded border border-(--color-mines-pale-blue) bg-white p-6">
            <div class="text-xs font-bold uppercase tracking-wider text-(--color-mines-red)">{course.data.code}</div>
            <h3 class="mt-2 text-lg font-bold text-(--color-mines-blue)">{course.data.name}</h3>
            <dl class="mt-4 text-sm text-(--color-body) space-y-1">
              <div class="flex gap-2"><dt class="font-semibold">Credits:</dt><dd>{course.data.credits}</dd></div>
              <div class="flex gap-2"><dt class="font-semibold">Offered:</dt><dd>{course.data.semesters?.join(', ') || 'TBD'}</dd></div>
              {course.data.instructor && (
                <div class="flex gap-2"><dt class="font-semibold">Instructor:</dt><dd>{course.data.instructor}</dd></div>
              )}
            </dl>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    headline="Explore the full catalog"
    body="Course descriptions, prerequisites, instructors, and open materials links for every automotive track course."
    primary={{ href: `${base}/courses/`, label: 'View all courses' }}
    secondary={{ href: `${base}/contact/`, label: 'Talk to an advisor' }}
  />

  <Footer slot="footer" />
</BaseLayout>
