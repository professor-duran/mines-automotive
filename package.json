{
  "name": "mines-automotive",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Preview site for the Colorado School of Mines Automotive Engineering Program. This repo is a mockup intended to hand off to Mines Communications and Marketing for eventual deployment on mines.edu via WordPress + Divi.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "export": "npm run build && tsx scripts/export-content.ts",
    "export:bundle": "npm run export && tsx scripts/bundle-export.ts",
    "test:a11y:axe": "npm run build && tsx scripts/a11y-axe.ts",
    "test:a11y:pa11y": "npm run build && tsx scripts/run-pa11y.ts",
    "test:a11y:lh": "npm run build && lhci autorun",
    "test:a11y": "npm run test:a11y:axe && npm run test:a11y:pa11y && npm run test:a11y:lh"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.102",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.7",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@types/archiver": "^7.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "archiver": "^7.0.1",
    "jsdom": "^29.0.2",
    "mdast-util-to-markdown": "^2.1.2",
    "pa11y-ci": "^4.1.0",
    "playwright": "^1.59.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "wait-on": "^9.0.5"
  }
}
